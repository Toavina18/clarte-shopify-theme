{{ 'section-about-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="about-hero color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="page-width" style="text-align:center;">
    {%- if section.settings.eyebrow != blank -%}
      <p class="about-hero__eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1 class="about-hero__heading">{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="about-hero__body">{{ section.settings.body }}</p>
    {%- endif -%}
  </div>

  <div class="about-hero__divider" aria-hidden="true"></div>

  <div class="about-hero__image-wrap">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          loading: 'eager',
          widths: '750, 900, 1200',
          sizes: '(min-width: 960px) 900px, 100vw'
      }}
    {%- else -%}
      {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.about-hero.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.about-hero.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.about-hero.settings.eyebrow.label",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.about-hero.settings.heading.label",
      "default": "We built CLARTÉ because nothing in the middle worked."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:sections.about-hero.settings.body.label",
      "default": "There is a gap in skincare. At one end: cheap products that do little. At the other: expensive serums that work but cost too much to use daily. We looked at why that gap exists — and built around it."
    },
    {
      "type": "header",
      "content": "t:sections.about-hero.settings.header_image.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.about-hero.settings.image.label"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 48
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "t:sections.about-hero.presets.name"
    }
  ]
}
{% endschema %}
