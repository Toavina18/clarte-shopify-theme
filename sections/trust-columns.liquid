{{ 'section-trust-columns.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- assign svg_lock = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>' -%}
{%- assign svg_refresh = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-4.18"/></svg>' -%}
{%- assign svg_shield_check = '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12l2 2 4-4"/><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>' -%}

<section class="trust-columns color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank -%}
    <h2 class="trust-columns__heading">{{ section.settings.heading }}</h2>
  {%- endif -%}

  <div class="trust-cols">
    {%- for block in section.blocks -%}
      {%- if block.type == 'trust_col' -%}
        <div class="trust-col" {{ block.shopify_attributes }}>
          <div class="trust-col__icon" aria-hidden="true">
            {%- case forloop.index -%}
              {%- when 1 -%}{{ svg_lock }}
              {%- when 2 -%}{{ svg_refresh }}
              {%- else -%}{{ svg_shield_check }}
            {%- endcase -%}
          </div>
          {%- if block.settings.title != blank -%}
            <div class="trust-col__title">{{ block.settings.title }}</div>
          {%- endif -%}
          {%- if block.settings.detail != blank -%}
            <div class="trust-col__detail">{{ block.settings.detail }}</div>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.trust-columns.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "trust_col",
      "name": "t:sections.trust-columns.blocks.trust_col.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.trust-columns.blocks.trust_col.settings.title.label",
          "default": "Secure Checkout"
        },
        {
          "type": "textarea",
          "id": "detail",
          "label": "t:sections.trust-columns.blocks.trust_col.settings.detail.label",
          "default": "SSL-encrypted. Your data is never stored or shared. Shopify-hosted payments."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.trust-columns.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.trust-columns.settings.heading.label",
      "default": "Our Commitments"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "t:sections.trust-columns.presets.name",
      "blocks": [
        { "type": "trust_col", "settings": { "title": "Secure Checkout", "detail": "SSL-encrypted. Your data is never stored or shared. Shopify-hosted payments." } },
        { "type": "trust_col", "settings": { "title": "30-Day Returns", "detail": "No visible improvement in 30 days of regular use? We refund you. No questions asked." } },
        { "type": "trust_col", "settings": { "title": "Real Ingredients", "detail": "EU-compliant formula. Fragrance-free. 24-hour reply on all business days." } }
      ]
    }
  ]
}
{% endschema %}
