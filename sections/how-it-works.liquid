{{ 'section-how-it-works.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="how-it-works color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding" id="how-it-works">
  {%- if section.settings.eyebrow != blank or section.settings.heading != blank -%}
    <div class="how-it-works__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="how-it-works__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="how-it-works__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="steps-grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'step' -%}
        <div class="step-card" {{ block.shopify_attributes }}>
          <div class="step-number" aria-hidden="true">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
          {%- if block.settings.title != blank -%}
            <h3 class="step-title">{{ block.settings.title }}</h3>
          {%- endif -%}
          {%- if block.settings.description != blank -%}
            <p class="step-desc">{{ block.settings.description }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.how-it-works.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "step",
      "name": "t:sections.how-it-works.blocks.step.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.how-it-works.blocks.step.settings.title.label",
          "default": "Apply each evening"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "t:sections.how-it-works.blocks.step.settings.description.label",
          "default": "2–3 drops to clean, dry skin. Start 3 nights per week."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.how-it-works.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.how-it-works.settings.eyebrow.label",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.how-it-works.settings.heading.label",
      "default": "Three steps. Smoother skin."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "t:sections.how-it-works.presets.name",
      "blocks": [
        {"type": "step", "settings": {"number": "01", "title": "Retinaldehyde Converts", "description": "Retinaldehyde converts directly to retinoic acid in skin. Works 11x faster than retinol."}},
        {"type": "step", "settings": {"number": "02", "title": "Gluconolactone Clears", "description": "PHAs dissolve dead skin without tearing the barrier."}},
        {"type": "step", "settings": {"number": "03", "title": "Ceramides Restore", "description": "Barrier lipids lock moisture in while actives work."}}
      ]
    }
  ]
}
{% endschema %}
