{{ 'section-product-highlight.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="product-highlight color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="product-highlight__inner">
    <div class="product-highlight__image">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            widths: '375, 550, 750, 1100',
            sizes: '(min-width: 769px) 50vw, 100vw'
        }}
      {%- else -%}
        {{ 'product-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="product-highlight__text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="product-highlight__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="product-highlight__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="product-highlight__body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="ph-benefit-list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'benefit' -%}
              <li class="ph-benefit-item" {{ block.shopify_attributes }}>
                <span class="ph-benefit-icon" aria-hidden="true">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                    <polyline points="20 6 9 17 4 12"/>
                  </svg>
                </span>
                <div>
                  {%- if block.settings.title != blank -%}
                    <div class="ph-benefit-title">{{ block.settings.title }}</div>
                  {%- endif -%}
                  {%- if block.settings.description != blank -%}
                    <div class="ph-benefit-desc">{{ block.settings.description }}</div>
                  {%- endif -%}
                </div>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="button button--primary">
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.product-highlight.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "benefit",
      "name": "t:sections.product-highlight.blocks.benefit.name",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "t:sections.product-highlight.blocks.benefit.settings.title.label",
          "default": "Smoother Texture"
        },
        {
          "type": "text",
          "id": "description",
          "label": "t:sections.product-highlight.blocks.benefit.settings.description.label",
          "default": "Retinaldehyde speeds cell renewal. Visible texture improvement from week 2."
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.product-highlight.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.product-highlight.settings.eyebrow.label",
      "default": "The Formula"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.product-highlight.settings.heading.label",
      "default": "One serum. Three results."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:sections.product-highlight.settings.body.label",
      "default": "A serum built around your skin's real needs. Retinaldehyde, gluconolactone, and ceramides working together to deliver visible texture improvement."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.product-highlight.settings.cta_text.label",
      "default": "Shop CLARTÉ — €29"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.product-highlight.settings.cta_link.label",
      "default": "/products/clarte-retinaldehyde-texture-serum"
    },
    {
      "type": "header",
      "content": "t:sections.product-highlight.settings.header_image.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.product-highlight.settings.image.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "t:sections.product-highlight.presets.name",
      "blocks": [
        { "type": "benefit", "settings": { "title": "Smoother Texture", "description": "Retinaldehyde speeds cell renewal. Rough, bumpy texture reduces from week two. Clinical data: texture improved after 8 weeks." } },
        { "type": "benefit", "settings": { "title": "Refined Pore Appearance", "description": "Retinaldehyde refines pore walls. Gluconolactone dissolves dead skin around each pore. Up to 20% smaller at 8 weeks." } },
        { "type": "benefit", "settings": { "title": "Makeup That Sits Better", "description": "Smooth skin is a better base. Foundation floats on instead of settling into bumps. Many users report needing less coverage." } }
      ]
    }
  ]
}
{% endschema %}
