{{ 'section-contact-header.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="contact-header-section color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="contact-header-section__inner">
    <div class="contact-header__text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="contact-header__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1 class="contact-header__h1">{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="contact-header__body">{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.promise != blank -%}
        <p class="contact-header__promise">{{ section.settings.promise }}</p>
      {%- endif -%}
      {%- if section.settings.hours != blank -%}
        <p class="contact-header__hours">{{ section.settings.hours }}</p>
      {%- endif -%}
    </div>

    <div class="contact-card" role="complementary" aria-label="Contact information">
      <span class="contact-card__label">{{ section.settings.email_label }}</span>
      <a href="mailto:{{ section.settings.email }}" class="contact-card__email">{{ section.settings.email }}</a>
      {%- if section.settings.response_time != blank -%}
        <p class="contact-card__response">{{ section.settings.response_time }}</p>
      {%- endif -%}

      <div class="contact-card__divider" aria-hidden="true"></div>

      <span class="contact-card__label">{{ section.settings.hours_label }}</span>
      <div class="contact-card__hours-text">
        <p>{{ section.settings.weekday_label }}</p>
        <p>{{ section.settings.weekday_hours }}</p>
        <p class="contact-card__hours-small">{{ section.settings.weekend_hours }}</p>
      </div>

      {%- if section.settings.instagram_url != blank or section.settings.tiktok_url != blank -%}
        <div class="contact-card__divider" aria-hidden="true"></div>
        <span class="contact-card__label">{{ section.settings.social_label }}</span>
        <div class="contact-card__social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" aria-label="CLARTÉ on Instagram">{{ section.settings.instagram_label }}</a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" aria-label="CLARTÉ on TikTok">{{ section.settings.tiktok_label }}</a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.contact-header.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.contact-header.settings.header_left.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.contact-header.settings.eyebrow.label",
      "default": "Get in Touch"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.contact-header.settings.heading.label",
      "default": "We're here. Talk to us."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:sections.contact-header.settings.body.label",
      "default": "We read every message. Skincare questions, orders, returns — all of it. Whether you have a question about your order, our formula, or just want to know if CLARTÉ is right for your skin — our team is ready."
    },
    {
      "type": "text",
      "id": "promise",
      "label": "t:sections.contact-header.settings.promise.label",
      "default": "We reply to every message within 24 hours."
    },
    {
      "type": "text",
      "id": "hours",
      "label": "t:sections.contact-header.settings.hours.label",
      "default": "Mon–Fri, 9:00–18:00 CET"
    },
    {
      "type": "header",
      "content": "t:sections.contact-header.settings.header_card.content"
    },
    {
      "type": "text",
      "id": "email",
      "label": "t:sections.contact-header.settings.email.label",
      "default": "hello@clarteserum.com"
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "t:sections.contact-header.settings.email_label.label",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "response_time",
      "label": "t:sections.contact-header.settings.response_time.label",
      "default": "Reply within 24 hours"
    },
    {
      "type": "text",
      "id": "hours_label",
      "label": "t:sections.contact-header.settings.hours_label.label",
      "default": "Support Hours"
    },
    {
      "type": "text",
      "id": "weekday_label",
      "label": "t:sections.contact-header.settings.weekday_label.label",
      "default": "Monday – Friday"
    },
    {
      "type": "text",
      "id": "weekday_hours",
      "label": "t:sections.contact-header.settings.weekday_hours.label",
      "default": "9:00 – 18:00 CET"
    },
    {
      "type": "text",
      "id": "weekend_hours",
      "label": "t:sections.contact-header.settings.weekend_hours.label",
      "default": "Saturday: 10:00–15:00 CET · Sunday: Closed"
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "t:sections.contact-header.settings.instagram_url.label"
    },
    {
      "type": "text",
      "id": "instagram_label",
      "label": "t:sections.contact-header.settings.instagram_label.label",
      "default": "Instagram ↗"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "t:sections.contact-header.settings.tiktok_url.label"
    },
    {
      "type": "text",
      "id": "tiktok_label",
      "label": "t:sections.contact-header.settings.tiktok_label.label",
      "default": "TikTok ↗"
    },
    {
      "type": "text",
      "id": "social_label",
      "label": "t:sections.contact-header.settings.social_label.label",
      "default": "Follow Us"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "t:sections.contact-header.presets.name"
    }
  ]
}
{% endschema %}
