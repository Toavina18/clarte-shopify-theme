{{ 'section-cta-block.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="cta-block color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="cta-block__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="cta-block__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}
    {%- if section.settings.intro_body != blank -%}
      <p class="cta-block__body">{{ section.settings.intro_body }}</p>
    {%- endif -%}
    {%- if section.settings.subheading != blank -%}
      <p class="cta-block__body">{{ section.settings.subheading }}</p>
    {%- endif -%}
    <div style="display:flex;flex-direction:column;align-items:center;gap:10px;margin-bottom:4px;">
      {%- if section.settings.cta_text != blank -%}
        <a href="{{ section.settings.cta_link }}" class="button button--primary">
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}
      {%- if section.settings.cta_secondary_text != blank -%}
        <a href="{{ section.settings.cta_secondary_link }}" class="cta-block__secondary-link">
          {{ section.settings.cta_secondary_text }}
        </a>
      {%- endif -%}
    </div>
    {%- if section.settings.guarantee != blank -%}
      <p class="cta-block__guarantee">{{ section.settings.guarantee }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.cta-block.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.cta-block.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.cta-block.settings.heading.label",
      "default": "Start with smoother skin."
    },
    {
      "type": "textarea",
      "id": "intro_body",
      "label": "t:sections.cta-block.settings.intro_body.label"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "t:sections.cta-block.settings.subheading.label",
      "default": "Retinaldehyde (precision retinoid). Gluconolactone (gentle acid). Ceramides (barrier support). €29. No lock-in. Free returns."
    },
    {
      "type": "header",
      "content": "t:sections.cta-block.settings.header_ctas.content"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "t:sections.cta-block.settings.cta_text.label",
      "default": "Add to Cart — €29"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "t:sections.cta-block.settings.cta_link.label",
      "default": "/products/clarte-retinaldehyde-texture-serum"
    },
    {
      "type": "text",
      "id": "cta_secondary_text",
      "label": "t:sections.cta-block.settings.cta_secondary_text.label"
    },
    {
      "type": "url",
      "id": "cta_secondary_link",
      "label": "t:sections.cta-block.settings.cta_secondary_link.label"
    },
    {
      "type": "text",
      "id": "guarantee",
      "label": "t:sections.cta-block.settings.guarantee.label"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "t:sections.cta-block.presets.name"
    }
  ]
}
{% endschema %}
