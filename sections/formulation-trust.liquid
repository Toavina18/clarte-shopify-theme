{{ 'section-formulation-trust.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="formulation-trust color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="formulation-trust__inner">
    <div class="formulation-trust__image">
      {%- if section.settings.image != blank -%}
        {{
          section.settings.image
          | image_url: width: 800
          | image_tag:
            loading: 'lazy',
            widths: '375, 550, 750, 1100',
            sizes: '(min-width: 769px) 50vw, 100vw'
        }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    </div>

    <div class="formulation-trust__text">
      {%- if section.settings.eyebrow != blank -%}
        <span class="formulation-trust__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="formulation-trust__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.body != blank -%}
        <p class="formulation-trust__body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.settings.credential_1 != blank or section.settings.credential_2 != blank or section.settings.credential_3 != blank -%}
        <ul class="credentials-list" role="list">
          {%- if section.settings.credential_1 != blank -%}
            <li>{{ section.settings.credential_1 }}</li>
          {%- endif -%}
          {%- if section.settings.credential_2 != blank -%}
            <li>{{ section.settings.credential_2 }}</li>
          {%- endif -%}
          {%- if section.settings.credential_3 != blank -%}
            <li>{{ section.settings.credential_3 }}</li>
          {%- endif -%}
        </ul>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="trust-list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_item' -%}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.promise != blank -%}
        <p class="formulation-trust__promise">{{ section.settings.promise }}</p>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.formulation-trust.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "trust_item",
      "name": "t:sections.formulation-trust.blocks.trust_item.name",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:sections.formulation-trust.blocks.trust_item.settings.text.label",
          "default": "EU-formulated under Regulation 1223/2009"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.formulation-trust.settings.header_image.content"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:sections.formulation-trust.settings.image.label"
    },
    {
      "type": "header",
      "content": "t:sections.formulation-trust.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.formulation-trust.settings.eyebrow.label",
      "default": "The Formulation"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.formulation-trust.settings.heading.label",
      "default": "Formulated by Cosmetic Scientists. Validated by Dermatologists."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:sections.formulation-trust.settings.body.label",
      "default": "The best retinoid — retinaldehyde — was used by luxury brands to justify high prices. No brand made it available at a price you could sustain. We looked at why that gap exists. The answer was simple. CLARTÉ changes that. Advanced retinoid. Honest price. Made for daily use."
    },
    {
      "type": "text",
      "id": "credential_1",
      "label": "t:sections.formulation-trust.settings.credential_1.label",
      "default": "Clinical study (n=42, 8 weeks)"
    },
    {
      "type": "text",
      "id": "credential_2",
      "label": "t:sections.formulation-trust.settings.credential_2.label",
      "default": "EU-formulated under Cosmetics Regulation 1223/2009"
    },
    {
      "type": "text",
      "id": "credential_3",
      "label": "t:sections.formulation-trust.settings.credential_3.label",
      "default": "Retinaldehyde not covered by EU Regulation 2024/996"
    },
    {
      "type": "textarea",
      "id": "promise",
      "label": "t:sections.formulation-trust.settings.promise.label",
      "default": "Our promise: If your skin does not visibly improve in 30 days of regular use, we refund you. No questions."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "t:sections.formulation-trust.presets.name",
      "blocks": [
        { "type": "trust_item", "settings": { "text": "EU-formulated under Regulation 1223/2009" } },
        { "type": "trust_item", "settings": { "text": "Fragrance-free — no sensitising fragrance ingredients" } },
        { "type": "trust_item", "settings": { "text": "No added silicones — absorbs cleanly" } },
        { "type": "trust_item", "settings": { "text": "Tested on reactive skin types" } },
        { "type": "trust_item", "settings": { "text": "Every ingredient has a function — nothing decorative" } }
      ]
    }
  ]
}
{% endschema %}
