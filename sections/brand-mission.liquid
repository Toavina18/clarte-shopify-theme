{{ 'section-brand-mission.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="brand-mission color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  <div class="brand-mission__inner">
    <div class="brand-mission__accent" aria-hidden="true"></div>
    {%- if section.settings.eyebrow != blank -%}
      <span class="brand-mission__eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    {%- if section.settings.statement != blank -%}
      <blockquote class="brand-mission__statement">
        &ldquo;{{ section.settings.statement }}&rdquo;
      </blockquote>
    {%- endif -%}
    {%- if section.settings.body != blank -%}
      <p class="brand-mission__body">{{ section.settings.body }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.brand-mission.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "t:sections.brand-mission.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.brand-mission.settings.eyebrow.label",
      "default": "Our Mission"
    },
    {
      "type": "textarea",
      "id": "statement",
      "label": "t:sections.brand-mission.settings.statement.label",
      "default": "To give everyone with textured skin access to the same actives found in clinic-grade serums — at a price that works every day."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:sections.brand-mission.settings.body.label",
      "default": "Precision skincare. Without the premium. Effective skincare should not cost €70 for 30ml. You should not ration your serum to twice a week just to make it last. Results come from using it daily. Daily use needs a price you can keep. CLARTÉ is €29 because that is what fair looks like."
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 150,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 100
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-2"
    }
  ],
  "presets": [
    {
      "name": "t:sections.brand-mission.presets.name"
    }
  ]
}
{% endschema %}
