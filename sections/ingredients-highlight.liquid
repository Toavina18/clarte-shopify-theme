{{ 'section-ingredients-highlight.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="ingredients-highlight color-{{ section.settings.color_scheme }} gradient section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank or section.settings.eyebrow != blank -%}
    <div class="ingredients-highlight__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="ingredients-highlight__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="ingredients-highlight__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="ingredients-highlight__cards">
    {%- for block in section.blocks -%}
      {%- case block.type -%}
        {%- when 'ingredient' -%}
          <div class="active-card active-card--{{ block.settings.card_style | default: 'default' }}" {{ block.shopify_attributes }}>
            <p class="active-card__name">{{ block.settings.name }}</p>
            {%- if block.settings.role != blank -%}
              <span class="active-card__tag">{{ block.settings.role }}</span>
            {%- endif -%}
            {%- if block.settings.description != blank -%}
              <div class="active-card__desc">{{ block.settings.description }}</div>
            {%- endif -%}
            {%- if block.settings.evidence_label != blank -%}
              <p class="active-card__evidence">{{ block.settings.evidence_label }}</p>
            {%- endif -%}
          </div>
      {%- endcase -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "t:sections.ingredients-highlight.name",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "blocks": [
    {
      "type": "ingredient",
      "name": "t:sections.ingredients-highlight.blocks.ingredient.name",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "t:sections.ingredients-highlight.blocks.ingredient.settings.name.label",
          "default": "Retinaldehyde 0.05%"
        },
        {
          "type": "text",
          "id": "role",
          "label": "t:sections.ingredients-highlight.blocks.ingredient.settings.role.label",
          "default": "Vitamin A Derivative"
        },
        {
          "type": "select",
          "id": "card_style",
          "label": "t:sections.ingredients-highlight.blocks.ingredient.settings.card_style.label",
          "options": [
            { "value": "default", "label": "t:sections.ingredients-highlight.blocks.ingredient.settings.card_style.options__1.label" },
            { "value": "accent", "label": "t:sections.ingredients-highlight.blocks.ingredient.settings.card_style.options__2.label" }
          ],
          "default": "default"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "t:sections.ingredients-highlight.blocks.ingredient.settings.description.label",
          "default": "<p>Describe how this ingredient works and why it is in the formula.</p>"
        },
        {
          "type": "text",
          "id": "evidence_label",
          "label": "t:sections.ingredients-highlight.blocks.ingredient.settings.evidence_label.label",
          "default": "Clinical evidence 8.5/10"
        }
      ]
    },
    {
      "type": "@app"
    }
  ],
  "settings": [
    {
      "type": "header",
      "content": "t:sections.ingredients-highlight.settings.header_content.content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:sections.ingredients-highlight.settings.eyebrow.label",
      "default": "The Formula"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:sections.ingredients-highlight.settings.heading.label",
      "default": "Three actives. One result."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:sections.all.colors.label",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:sections.all.padding.header_padding.content"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top.label",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom.label",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "t:sections.ingredients-highlight.presets.name",
      "blocks": [
        { "type": "ingredient", "settings": { "name": "Retinaldehyde 0.05%", "role": "Vitamin A Derivative", "card_style": "accent", "description": "<p>Converts directly to retinoic acid in skin. Works 11x faster than retinol with less irritation. Speeds cell renewal, smooths texture, refines pores.</p>", "evidence_label": "Clinical evidence 8.5/10" } },
        { "type": "ingredient", "settings": { "name": "Gluconolactone 4%", "role": "Polyhydroxy Acid (PHA)", "card_style": "default", "description": "<p>Dissolves dead skin cells without tearing the barrier. Safe for reactive skin. Clears around pores. Hydrates as it exfoliates.</p>", "evidence_label": "Clinical evidence 7.8/10" } },
        { "type": "ingredient", "settings": { "name": "Ceramide Complex", "role": "Barrier Lipids", "card_style": "default", "description": "<p>Three ceramide types that restore and reinforce the skin barrier. Locks moisture in while actives work overnight. Reduces sensitivity.</p>", "evidence_label": "Clinical evidence 8.0/10" } }
      ]
    }
  ]
}
{% endschema %}
