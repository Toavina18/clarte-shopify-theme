    "ingredients-highlight": {
      "type": "ingredients-highlight",
      "blocks": {
        "ing-1": {
          "type": "ingredient",
          "settings": {
            "name": "Retinaldehyde 0.05%",
            "role": "Vitamin A Derivative",
            "card_style": "accent",
            "evidence_label": "Clinical evidence score: 8.5/10",
            "description": "<p>Retinaldehyde is a retinoid — a vitamin A form. It is one step from what skin cells use. It works faster than retinol. Less irritation too. It speeds cell renewal. It fades marks. It refines pores. In CLARTÉ it is released slowly. This cuts the risk of a reaction. Not covered by EU retinol rules.</p>"
          }
        },
        "ing-2": {
          "type": "ingredient",
          "settings": {
            "name": "Gluconolactone (PHA)",
            "role": "Poly-Hydroxy Acid",
            "card_style": "default",
            "evidence_label": "Clinical evidence score: 7.8/10",
            "description": "<p>Gluconolactone is a PHA acid. Its molecule is large. It stays on the skin surface. No deep burn. No irritation. It clears dead skin. It unclogs pores. It smooths texture. Safe for reactive skin.</p>"
          }
        },
        "ing-3": {
          "type": "ingredient",
          "settings": {
            "name": "Ceramides Complex",
            "role": "Barrier Lipids",
            "card_style": "default",
            "evidence_label": "Clinical evidence score: 7.2/10",
            "description": "<p>Ceramides are lipids in your skin barrier. They stop water loss and block irritants. While retinaldehyde and gluconolactone resurface, ceramides repair. Skin stays strong and hydrated.</p>"
          }
        }
      },
      "block_order": [
        "ing-1",
        "ing-2",
        "ing-3"
      ],
      "settings": {
        "eyebrow": "The Actives",
        "heading": "Three actives. One result.",
