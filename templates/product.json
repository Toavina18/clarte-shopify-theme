          "type": "faq_item",
          "settings": {
            "item_style": "default",
            "question": "How is retinaldehyde different from retinol?",
            "answer": "One step closer to the form your skin uses directly. Works faster at lower amounts. Less irritation. Not covered by EU retinol rules."
          }
        },
